{
	"name": "gha-matrix-tester",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"start": "go run . -dev -watch",
		"build": "go run .",
		"format:fix": "bunx @biomejs/biome check --write ./src",
		"typecheck": "tsc --noEmit",
		"vet": "bun typecheck && bunx @biomejs/biome check",
		"vet:ci": "bun typecheck && bunx @biomejs/biome ci",
		"test": "bun run vet",
		"test:ci": "bun run vet:ci"
	},
	"license": "Mozilla Public License 2.0",
	"dependencies": {
		"@fortawesome/fontawesome-svg-core": "^7.2.0",
		"@fortawesome/free-brands-svg-icons": "^7.2.0",
		"@fortawesome/free-regular-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@fortawesome/react-fontawesome": "^3.3.1",
		"@uiw/react-textarea-code-editor": "^3.1.1",
		"json-stringify-deterministic": "^1.0.13",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"yaml": "^2.9.0",
		"yup": "^1.7.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"esbuild": "0.28.1",
		"postcss": "^8.5.15",
		"postcss-cli": "^11.0.1",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3"
	}
}
